{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://*"
        },
        {
          "url": "https://*"
        }
      ]
    },
    "mobile-sharetarget:default",
    "core:default",
    "clipboard-manager:allow-read-text",
    "i18n:default",
    "os:allow-os-type",
    "os:allow-locale",
    "opener:default",
    "tts:allow-speak",
    "tts:allow-stop",
    "tts:allow-get-voices",
    "tts:allow-is-initialized",
    "tts:allow-register-listener",
    "safe-area-insets-css:default",
    "dialog:default",
    "media-session:allow-update-state",
    "media-session:allow-clear",
    "media-session:allow-register-listener",
    "media-session:allow-remove-listener",
    "http:default"
  ],
  "platforms": [
    "android",
    "iOS"
  ]
}
